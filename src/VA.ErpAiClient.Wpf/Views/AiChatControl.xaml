<UserControl x:Class="VA.ErpAiClient.Wpf.Views.AiChatControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="420"
             MinHeight="360">
    <Grid Background="#111827" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1F2937" Padding="14" BorderBrush="#374151" BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock Text="AI Nội bộ"
                           Foreground="#F9FAFB"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Giai đoạn 1: Chat demo qua AI API"
                           Foreground="#D1D5DB"
                           FontSize="13"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" Padding="14">
            <StackPanel x:Name="ChatPanel"/>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#1F2937" Padding="12" BorderBrush="#374151" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="txtMessage"
                         Grid.Column="0"
                         MinHeight="42"
                         MaxHeight="120"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         FontSize="15"
                         Foreground="#111827"
                         Background="#F9FAFB"
                         Padding="10"
                         KeyDown="TxtMessage_KeyDown"/>

                <Button x:Name="btnSend"
                        Grid.Column="2"
                        Content="Gửi"
                        Width="92"
                        MinHeight="42"
                        FontWeight="SemiBold"
                        Click="BtnSend_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
